{
  "name": "@f5-sales-demo/xcsh-chrome-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build.ts",
    "build:dev": "bun build.ts && node scripts/inject-key.mjs",
    "watch:dev": "node scripts/dev-watch.mjs",
    "test": "bun test",
    "check:types": "tsc -p tsconfig.typecheck.json --noEmit",
    "uat:overlay": "bun run build:dev && node test/uat/overlay-render.mjs",
    "uat:statusbar": "bun test/uat/statusbar-powerline.mjs"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/preact": "^3.2.4",
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.2.0",
    "happy-dom": "^20.10.6",
    "linkedom": "^0.18.5",
    "puppeteer-core": "^25.3.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "preact": "^10.29.4"
  }
}
