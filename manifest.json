{
  "manifest_version": 3,
  "name": "xcsh for F5 XC",
  "description": "xcsh Chrome extension for F5 Distributed Cloud console automation",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": [
    "debugger",
    "nativeMessaging",
    "scripting",
    "tabs",
    "webNavigation",
    "activeTab",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.volterra.us/*",
    "https://*.console.ves.volterra.io/*"
  ],
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.volterra.us/*",
        "https://*.console.ves.volterra.io/*"
      ],
      "js": ["dist/accessibility-tree.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}
